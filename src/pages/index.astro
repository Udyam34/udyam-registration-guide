---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Udyam &amp; MSME Guide</h1>
			<p>
				Plain-English, up-to-date guides to Udyam Registration and the MSME
				processes Indian business owners actually get stuck on — downloading your
				certificate, finding the right NIC code, recovering a lost Udyam number,
				and more. No jargon, just the steps.
			</p>
			<p>
				New to this? Once you're ready to
				<a href="https://www.udyam-registration.com/">apply for Udyam registration</a>,
				use the guides below for everything that comes after.
			</p>
			<h2>Popular guides</h2>
			<ul>
				<li><a href="/blog/download-udyam-certificate/">How to download your Udyam Registration certificate</a></li>
				<li><a href="/blog/find-nic-code-udyam-registration/">How to find the right NIC code for Udyam registration</a></li>
				<li><a href="/blog/recover-forgotten-udyam-number/">How to recover a lost or forgotten Udyam number</a></li>
			</ul>
			<p>Browse all articles on the <a href="/blog/">blog</a>.</p>
		</main>
		<Footer />
	</body>
</html>
